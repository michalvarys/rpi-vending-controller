# Host port where the hub dashboard is published. Inside the container it's always 8080.
PORT=8080

# How often (seconds) the hub refreshes state/logs from each RPi.
POLL_INTERVAL=3

# Per-request timeout when talking to an RPi.
POLL_TIMEOUT=4

# Rotation window for QR access tokens. Must match QR_ROTATE_SECONDS on every RPi.
QR_ROTATE_SECONDS=60

# HTTP Basic Auth for the dashboard and control endpoints. If unset, the hub is OPEN
# (only acceptable on a tailnet-only deployment). For public exposure, ALWAYS set.
# Generate: openssl rand -base64 24
HUB_ADMIN_USER=admin
HUB_ADMIN_PASSWORD=
