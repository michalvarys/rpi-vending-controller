# Token used by Odoo / central hub to authenticate webhook calls.
# Generate with: openssl rand -base64 32 | tr -d '=+/' | cut -c1-43
WEBHOOK_TOKEN=change-me-to-a-random-string

# Friendly label shown on dashboards. Defaults to hostname when blank.
DEVICE_NAME=rpi-vending

# Host port to expose the dashboard on. Inside the container we always listen on 8080.
PORT=8080

# Optional — free-form location label shown in the hub dashboard (e.g. "Praha, Vinohrady").
LOCATION=

# QR activation flow. QR_BASE_URL is the public address of the shop that will validate
# the QR token. Production points to https://automaty.elite-trafika.cz; for dev or
# tailnet-only testing leave blank or use http://varyshop-trafika-vps:8081 (shop-mock).
QR_BASE_URL=https://automaty.elite-trafika.cz
QR_ROTATE_SECONDS=60
