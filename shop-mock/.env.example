# Host port where the login UI is exposed. Shop-mock uses network_mode: host, so this binds directly.
PORT=8081

# Where the trafika-hub is reachable from THIS host (server-to-server, internal).
HUB_URL=http://127.0.0.1:8080

# Public-facing hub URL shown in browser links (admin "Open hub" button etc.).
# Must be reachable from the customer/admin's device. Leave blank to fall back to HUB_URL
# (only sensible in tailnet-only deployments).
HUB_PUBLIC_URL=https://hub.elite-trafika.cz

# Optional — admin fallback target when logging in WITHOUT a QR scan. Customers
# always need a QR-derived pinned_rpi regardless of this value. Leave blank if
# you want admins to be forced to use the hub dashboard for direct control.
RPI_HOSTNAME=

# Flask session secret — generate with: openssl rand -hex 32
# Keep this stable between restarts if you want sessions to survive.
SESSION_SECRET=change-me-64-hex-chars

# Presence / auto-off tuning:
# - HEARTBEAT_TIMEOUT_SECONDS: max time without a liveness ping (browser sends every 10s).
#   Catches tab closed / crash / network drop / sleep — orthogonal to the user-facing timer.
# - SESSION_DURATION_SECONDS: initial countdown granted on login. Relay off when it hits 0.
# - EXTEND_SECONDS: how much each "Prodloužit" click adds to the timer.
# - MAX_SESSION_SECONDS: hard cap per session. Extend never goes beyond this from login time.
HEARTBEAT_TIMEOUT_SECONDS=30
SESSION_DURATION_SECONDS=60
EXTEND_SECONDS=30
MAX_SESSION_SECONDS=900
