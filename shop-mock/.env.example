# Host port where the login UI is exposed. Shop-mock uses network_mode: host, so this binds directly.
PORT=8081

# Where the trafika-hub is reachable from this host.
HUB_URL=http://127.0.0.1:8080

# Which RPi this shop drives. Must match a hostname registered in hub/rpis.yml.
RPI_HOSTNAME=rpi-vending

# Flask session secret — generate with: openssl rand -hex 32
# Keep this stable between restarts if you want sessions to survive.
SESSION_SECRET=change-me-64-hex-chars

# Presence / auto-off tuning:
# - HEARTBEAT_TIMEOUT_SECONDS: how long server waits without a heartbeat ping before dropping a session.
#   Browser sends one every 10s, so 30s = ~2 missed beats before cleanup.
# - MAX_SESSION_SECONDS: hard cap per session. Relay off even if browser keeps pinging.
HEARTBEAT_TIMEOUT_SECONDS=30
MAX_SESSION_SECONDS=900
